# ============================================================
# SEGALLA - SISTEMA DE ORÇAMENTOS
# Arquivo de Variáveis de Ambiente (.env.example)
# ============================================================
# Copie este arquivo para .env e configure com seus valores
# cp .env.example .env

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
# Porta em que o servidor será executado
NODE_ENV=production
PORT=3000

# ─── BANCO DE DADOS (MySQL/MariaDB) ───────────────────────────────────────────
# Conexão com o banco de dados principal (orçamentos, usuários, formas de pagamento)
# Formato: mysql://usuario:senha@host:porta/banco_de_dados
DATABASE_URL=mysql://root:senha_segura@localhost:3306/segalla_orcamentos

# ─── FIREBIRD 2.5 (Estoque de Produtos) ──────────────────────────────────────
# Configuração de conexão com o servidor Firebird que contém o estoque de produtos
# O sistema APENAS CONSULTA o Firebird, nunca altera dados

# IP ou hostname do servidor Firebird
FIREBIRD_HOST=192.168.1.100

# Porta do servidor Firebird (padrão: 3050)
FIREBIRD_PORT=3050

# Caminho completo do arquivo de banco de dados Firebird
FIREBIRD_DATABASE=/dados/estoque.fdb

# Usuário do Firebird (padrão: SYSDBA)
FIREBIRD_USER=SYSDBA

# Senha do Firebird
FIREBIRD_PASSWORD=masterkey

# Charset do Firebird (padrão: WIN1252)
FIREBIRD_CHARSET=WIN1252

# ─── CONFIGURAÇÃO DAS TABELAS FIREBIRD ────────────────────────────────────────
# Nomes das 4 tabelas que contêm informações de produtos
FIREBIRD_TABLE_PRODUCTS=TESTPRODUTOGERAL
FIREBIRD_TABLE_STOCK=TESTEESTOQUE
FIREBIRD_TABLE_PRICES=TESTPRODUTO
FIREBIRD_TABLE_BRANDS=TESTMARCA

# ─── CAMPOS DAS TABELAS FIREBIRD ──────────────────────────────────────────────
FIREBIRD_FIELD_PRODUCT_CODE=CODIGO
FIREBIRD_FIELD_PRODUCT_NAME=DESCRICAO
FIREBIRD_FIELD_STOCK_CODE=CODIGO
FIREBIRD_FIELD_STOCK_BRAND_CODE=CODIGO_MARCA
FIREBIRD_FIELD_STOCK_QUANTITY=ESTOQUE
FIREBIRD_FIELD_PRICE_CODE=CODIGO
FIREBIRD_FIELD_PRICE_VALUE=VALOR
FIREBIRD_FIELD_BRAND_CODE=CODIGO
FIREBIRD_FIELD_BRAND_NAME=NOME

# ─── AUTENTICAÇÃO LOCAL ───────────────────────────────────────────────────────
# Chave secreta para assinatura de tokens JWT
JWT_SECRET=sua_chave_secreta_muito_segura_aqui_com_minimo_32_caracteres

# ─── INFORMAÇÕES DA EMPRESA ───────────────────────────────────────────────────
COMPANY_NAME=Segalla Peças Automotivas
COMPANY_TAGLINE=Qualidade e confiança para sua oficina
COMPANY_PHONE=(11) 3000-0000
COMPANY_EMAIL=contato@segalla.com.br
COMPANY_ADDRESS=Rua das Peças, 123 - São Paulo/SP

# ─── SEGURANÇA ────────────────────────────────────────────────────────────────
SESSION_TIMEOUT=480
MAX_LOGIN_ATTEMPTS=5
LOGIN_BLOCK_TIME=15

# ─── LOGS ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=./logs/app.log
ERROR_LOG_FILE=./logs/error.log

# ─── BACKUP ───────────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_FREQUENCY=24
MAX_BACKUPS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── DESENVOLVIMENTO ──────────────────────────────────────────────────────────
DEBUG=false
AUTO_SEED=false
